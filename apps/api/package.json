{
  "name": "api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development nodemon --watch 'src/**/*.ts' --exec 'node --loader ts-node/esm --no-warnings' src/index.ts",
    "test": "NODE_ENV=test DATABASE_URL=postgresql://buildpulse:buildpulse@localhost:5432/buildpulse_test JWT_ACCESS_SECRET=test-access-secret JWT_REFRESH_SECRET=test-refresh-secret node --loader ts-node/esm test/messagingAttachments.test.ts",
    "build": "npm run clean && tsc",
    "start": "NODE_ENV=production node dist/src/index.js",
    "prisma:studio": "cd database && npx prisma studio --config ./prisma.config.ts",
    "prisma:generate": "cd database && npx prisma generate --config ./prisma.config.ts",
    "prisma:deploy": "cd database && npx prisma migrate deploy --config ./prisma.config.ts",
    "prisma:migrate": "cd database && npx prisma migrate dev --config ./prisma.config.ts",
    "prisma:reset": "cd database && npx prisma migrate reset --config ./prisma.config.ts",
    "clean": "rm -rf dist"
  },
  "keywords": [],
