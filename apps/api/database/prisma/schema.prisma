// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CompanyBillingStatus {
  UNPAID
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum CompanySubcontractorAccessStatus {
  PENDING
  ACCEPTED
  REVOKED
}

model Company {
  id                        String               @id @default(uuid())
  name                      String
  billingStatus             CompanyBillingStatus @default(UNPAID) @map("billing_status")
  paymentProvider           String?              @map("payment_provider")
  paymentCustomerId         String?              @unique @map("payment_customer_id")
  paymentSubscriptionId     String?              @unique @map("payment_subscription_id")
  paymentSubscriptionItemId String?              @unique @map("payment_subscription_item_id")
  paymentSeatQuantity       Int                  @default(0) @map("payment_seat_quantity")
  paidUntil                 DateTime?            @map("paid_until")
  createdAt                 DateTime             @default(now()) @map("created_at")
  updatedAt                 DateTime             @updatedAt @map("updated_at")

  users                    User[]
  workPoints               WorkPoint[]
  invitations              Invitation[]
  chats                    Chat[]
  pendingPaidRegistrations PendingPaidRegistration[]
  ownedSubcontractorAccess CompanySubcontractorAccess[] @relation("OwnerCompanySubcontractorAccess")
  subcontractorAccess      CompanySubcontractorAccess[] @relation("SubcontractorCompanyAccess")

  @@index([billingStatus])
  @@map("companies")
}

model PendingPaidRegistration {
  id                      String    @id @default(uuid())
  username                String
  email                   String
  passwordHash            String    @map("password_hash")
  companyName             String    @map("company_name")
  stripeCheckoutSessionId String?   @unique @map("stripe_checkout_session_id")
  stripeCustomerId        String?   @map("stripe_customer_id")
  stripeSubscriptionId    String?   @map("stripe_subscription_id")
  companyId               String?   @map("company_id")
  userId                  String?   @map("user_id")
  expiresAt               DateTime  @map("expires_at")
  completedAt             DateTime? @map("completed_at")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([username])
  @@index([expiresAt])
  @@map("pending_paid_registrations")
}

model ProcessedStripeWebhookEvent {
  id        String   @id
  type      String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("processed_stripe_webhook_events")
}

model User {
  id         String @id @default(uuid())
  username   String @unique
  email      String @unique
  password   String
  role       String
  hourlyWage Float? @map("hourly_wage")
  companyId  String @map("company_id")

  company                    Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workPoints                 WorkPoint[]
  invitations                Invitation[]        @relation("InvitedBy")
  assignedWorkPoints         WorkPoint[]         @relation("WorkPointWorkers")
  attendances                Attendance[]
  chatParticipants           ChatParticipant[]
  sentMessages               Message[]
  workerDocuments            WorkerDocument[]    @relation("WorkerDocuments")
  uploadedDocuments          WorkerDocument[]    @relation("UploadedWorkerDocuments")
  uploadedWorkPointDocuments WorkPointDocument[] @relation("UploadedWorkPointDocuments")
  refreshTokens              RefreshToken[]
  passwordResetTokens        PasswordResetToken[]
  pushDevices                PushDevice[]
  leaveRequests              LeaveRequest[]      @relation("LeaveRequestUser")
  reviewedLeaveRequests      LeaveRequest[]      @relation("LeaveRequestReviewer")
  sentSubcontractorInvites   CompanySubcontractorAccess[] @relation("SubcontractorInvitedBy")
  acceptedSubcontractorInvites CompanySubcontractorAccess[] @relation("SubcontractorAcceptedBy")

  @@index([companyId])
}

model WorkPoint {
  id          String              @id @default(uuid())
  name        String
  address     String
  lat         Float?
  lng         Float?
  description String?
  userId      String?             @map("user_id")
  uploadedAt  DateTime            @default(now())
  deadline    DateTime?
  qrToken     String              @unique @default(uuid()) @map("qr_token")
  companyId   String              @map("company_id")
  company     Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User?               @relation(fields: [userId], references: [id])
  workers     User[]              @relation("WorkPointWorkers")
  attendances Attendance[]
  documents   WorkPointDocument[]
  chat        Chat?

  @@index([companyId])
}

model Invitation {
  id          String    @id @default(uuid())
  email       String
  role        String
  token       String    @unique
  invitedById String?   @map("invited_by_id")
  companyId   String    @map("company_id")
  expiresAt   DateTime  @map("expires_at")
  acceptedAt  DateTime? @map("accepted_at")
  revokedAt   DateTime? @map("revoked_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invitedBy User?   @relation("InvitedBy", fields: [invitedById], references: [id])

  @@index([companyId])
  @@index([companyId, email])
  @@map("invitations")
}

model CompanySubcontractorAccess {
  id                     String                              @id @default(uuid())
  ownerCompanyId          String                              @map("owner_company_id")
  subcontractorCompanyId  String                              @map("subcontractor_company_id")
  status                 CompanySubcontractorAccessStatus    @default(PENDING)
  token                  String                              @unique
  invitedAdminEmail       String                              @map("invited_admin_email")
  invitedById             String?                             @map("invited_by_id")
  acceptedById            String?                             @map("accepted_by_id")
  expiresAt              DateTime                            @map("expires_at")
  acceptedAt             DateTime?                           @map("accepted_at")
  revokedAt              DateTime?                           @map("revoked_at")
  createdAt              DateTime                            @default(now()) @map("created_at")
  updatedAt              DateTime                            @updatedAt @map("updated_at")

  ownerCompany         Company @relation("OwnerCompanySubcontractorAccess", fields: [ownerCompanyId], references: [id], onDelete: Cascade)
  subcontractorCompany Company @relation("SubcontractorCompanyAccess", fields: [subcontractorCompanyId], references: [id], onDelete: Cascade)
  invitedBy            User?   @relation("SubcontractorInvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)
  acceptedBy           User?   @relation("SubcontractorAcceptedBy", fields: [acceptedById], references: [id], onDelete: SetNull)

  @@unique([ownerCompanyId, subcontractorCompanyId])
  @@index([ownerCompanyId])
  @@index([subcontractorCompanyId])
  @@index([status])
  @@index([expiresAt])
  @@map("company_subcontractor_access")
}

model Attendance {
  id             String    @id @default(uuid())
  workerId       String    @map("worker_id")
  workPointId    String    @map("work_point_id")
  date           DateTime  @map("date") @db.Date
  checkedInAt    DateTime  @default(now()) @map("checked_in_at")
  checkedOutAt   DateTime? @map("checked_out_at")
  checkoutSource String?   @map("checkout_source")
  source         String

  worker    User      @relation(fields: [workerId], references: [id], onDelete: Cascade)
  workPoint WorkPoint @relation(fields: [workPointId], references: [id], onDelete: Cascade)

  @@unique([workerId, workPointId, date])
  @@index([workPointId, date])
  @@map("attendances")
}

model WorkerDocument {
  id           String   @id @default(uuid())
  workerId     String   @map("worker_id")
  uploadedById String?  @map("uploaded_by_id")
  originalName String   @map("original_name")
  storedName   String   @unique @map("stored_name")
  mimeType     String   @map("mime_type")
  sizeBytes    Int      @map("size_bytes")
  createdAt    DateTime @default(now()) @map("created_at")

  worker     User  @relation("WorkerDocuments", fields: [workerId], references: [id], onDelete: Cascade)
  uploadedBy User? @relation("UploadedWorkerDocuments", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([workerId, createdAt])
  @@index([uploadedById])
  @@map("worker_documents")
}

model WorkPointDocument {
  id           String   @id @default(uuid())
  workPointId  String   @map("work_point_id")
  uploadedById String?  @map("uploaded_by_id")
  originalName String   @map("original_name")
  storedName   String   @unique @map("stored_name")
  mimeType     String   @map("mime_type")
  sizeBytes    Int      @map("size_bytes")
  createdAt    DateTime @default(now()) @map("created_at")

  workPoint  WorkPoint @relation(fields: [workPointId], references: [id], onDelete: Cascade)
  uploadedBy User?     @relation("UploadedWorkPointDocuments", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([workPointId, createdAt])
  @@index([uploadedById])
  @@map("workpoint_documents")
}

model RefreshToken {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  jtiHash           String    @unique @map("jti_hash")
  expiresAt         DateTime  @map("expires_at")
  revokedAt         DateTime? @map("revoked_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  replacedByTokenId String?   @map("replaced_by_token_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model PushDevice {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  token      String   @unique
  platform   String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  lastSeenAt DateTime @default(now()) @map("last_seen_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_devices")
}

enum LeaveRequestType {
  VACATION
  SICK
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model LeaveRequest {
  id         String             @id @default(uuid())
  userId     String             @map("user_id")
  type       LeaveRequestType
  startDate  DateTime           @map("start_date") @db.Date
  endDate    DateTime           @map("end_date") @db.Date
  status     LeaveRequestStatus @default(PENDING)
  createdAt  DateTime           @default(now()) @map("created_at")
  reviewedAt DateTime?          @map("reviewed_at")
  reviewedBy String?            @map("reviewed_by")

  user     User  @relation("LeaveRequestUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewer User? @relation("LeaveRequestReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([userId, startDate, endDate])
  @@index([status])
  @@index([reviewedBy])
  @@map("leave_requests")
}

// ─── Messaging ───────────────────────────────────────────────────────────────

enum ChatType {
  DIRECT
  GROUP
  WORKPOINT
}

model Chat {
  id            String    @id @default(uuid())
  type          ChatType
  name          String?
  workPointId   String?   @unique @map("work_point_id")
  companyId     String    @map("company_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  lastMessageAt DateTime? @map("last_message_at")

  company      Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workPoint    WorkPoint?        @relation(fields: [workPointId], references: [id], onDelete: Cascade)
  participants ChatParticipant[]
  messages     Message[]

  @@index([companyId])
  @@index([lastMessageAt])
  @@map("chats")
}

model ChatParticipant {
  id         String    @id @default(uuid())
  chatId     String    @map("chat_id")
  userId     String    @map("user_id")
  joinedAt   DateTime  @default(now()) @map("joined_at")
  lastReadAt DateTime? @map("last_read_at")

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([userId])
  @@map("chat_participants")
}

model Message {
  id             String    @id @default(uuid())
  chatId         String    @map("chat_id")
  senderId       String    @map("sender_id")
  body           String
  attachmentUrl  String?   @map("attachment_url")
  attachmentName String?   @map("attachment_name")
  attachmentType String?   @map("attachment_type")
  replyToId      String?   @map("reply_to_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  editedAt       DateTime? @map("edited_at")

  chat    Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender  User      @relation(fields: [senderId], references: [id], onDelete: Cascade)
  replyTo Message?  @relation("MessageReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies Message[] @relation("MessageReply")

  @@index([chatId, createdAt])
  @@map("messages")
}
