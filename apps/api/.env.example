# Copy this file to `.env.development` for local work or `.env.production` for deployment.
# The app selects the file based on `NODE_ENV`.

PORT=4000
ATTENDANCE_TIMEZONE=Europe/Bucharest

DB_USER=buildpulse
DB_PASSWORD=replace-me
DB_NAME=buildpulse
DB_HOST=localhost
DB_PORT=5432
DB_SSL=false

DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?sslmode=${DB_SSL}
JWT_ACCESS_SECRET=replace-with-a-random-secret-at-least-32-characters
JWT_REFRESH_SECRET=replace-with-another-random-secret-at-least-32-characters

FRONTEND_BASE_URL=http://localhost:5173
APP_BASE_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
AUTH_COOKIE_SAME_SITE=lax
FIREBASE_SERVICE_ACCOUNT_JSON=

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=BuildPulse <no-reply@your-domain.com>
